rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isProfessor() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userType == "professor";
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOccupancyOwner() {
      return isSignedIn() &&
        resource != null &&
        resource.data.uid == request.auth.uid;
    }

    function writesOwnOccupancy() {
      return isSignedIn() &&
        request.resource != null &&
        request.resource.data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isSelf(userId);
    }

    // Temporary demo rule set for class-project hosting without Cloud Functions.
    match /layouts/{layoutId} {
      allow read, write: if isSignedIn();
    }

    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();

      match /seats/{seatId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /seatTags/{tagId} {
        allow read, write: if isSignedIn();
      }

      match /checkins/{uid} {
        allow read: if isProfessor() || isSelf(uid);
        allow create, delete: if isProfessor() || isSelf(uid);
        allow update: if isProfessor() || isSelf(uid);
      }

      match /occupancy/{seatId} {
        allow read: if isSignedIn();
        allow create, update: if isProfessor() || writesOwnOccupancy();
        allow delete: if isProfessor() || isOccupancyOwner();
      }
    }
  }
}

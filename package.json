{
  "name": "wh0-r-u-aga1n",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "npx expo start",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "web": "npx expo start --web",
    "generate:seat-qrs": "node --import tsx scripts/generateSeatQRCodes.ts",
    "typecheck": "tsc --noEmit && npm --prefix functions run lint",
    "test": "npm run test:domain && npm run test:app",
    "test:domain": "node --import tsx --test --test-concurrency=1 \"test/domain/**/*.test.ts\"",
    "test:firebase": "npm --prefix functions run build && firebase emulators:exec --project demo-wh0ru-aga1n --only auth,firestore,functions \"node --import tsx --test --test-concurrency=1 \\\"test/firebase/**/*.test.ts\\\"\"",
    "test:app": "jest --config jest.config.app.js --runInBand",
    "test:ci": "npm run typecheck && npm run test:domain && npm run test:firebase && npm run test:app",
    "emulators": "npm --prefix functions run build && firebase emulators:start --project demo-wh0ru-aga1n --only auth,firestore,functions"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~52.0.0",
    "expo-blur": "~14.0.0",
    "expo-camera": "~16.0.0",
    "expo-constants": "~17.0.0",
    "expo-image-manipulator": "~13.0.6",
    "expo-image-picker": "~16.0.6",
    "expo-linking": "~7.0.0",
    "expo-router": "~4.0.0",
    "expo-status-bar": "~2.0.0",
    "firebase": "^11.0.0",
    "lucide-react-native": "^0.460.0",
    "nativewind": "^4.1.23",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "~15.8.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.0",
    "firebase-tools": "^15.14.0",
    "jest": "^29.7.0",
    "jest-expo": "^52.0.5",
    "qrcode-terminal": "0.11.0",
    "react-test-renderer": "^18.3.1",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.3.0"
  },
  "private": true
}

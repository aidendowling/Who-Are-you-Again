[debug] [2026-04-15T20:41:57.881Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/demo-wh0ru-aga1n:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n    function isSignedIn() {\r\n      return request.auth != null;\r\n    }\r\n\r\n    function currentUser() {\r\n      if (!isSignedIn()) {\r\n        return null;\r\n      }\r\n      let user = get(/databases/$(database)/documents/users/$(request.auth.uid));\r\n      return user.data != null ? user : null;\r\n    }\r\n\r\n    function isProfessor() {\r\n      let user = currentUser();\r\n      return user != null && user.data.userType == \"professor\";\r\n    }\r\n\r\n    match /users/{userId} {\r\n      allow read: if isSignedIn() && (\r\n        request.auth.uid == userId ||\r\n        get(/databases/$(database)/documents/users/$(userId)).data.userType == \"professor\"\r\n      );\r\n      allow write: if isSignedIn() && request.auth.uid == userId;\r\n    }\r\n\r\n    match /rooms/{roomId} {\r\n      allow read: if isSignedIn();\r\n      allow write: if isProfessor();\r\n\r\n      match /seats/{seatId} {\r\n        allow read: if isSignedIn();\r\n        allow write: if isProfessor();\r\n      }\r\n\r\n      match /seatTags/{tagId} {\r\n        allow read: if isProfessor();\r\n        allow write: if isProfessor();\r\n      }\r\n\r\n      match /checkins/{uid} {\r\n        allow read: if isProfessor() || (isSignedIn() && request.auth.uid == uid);\r\n        allow create, delete: if isProfessor();\r\n        allow update: if isProfessor() || (\r\n          isSignedIn() &&\r\n          request.auth.uid == uid &&\r\n          request.resource.data.diff(resource.data).changedKeys().hasOnly([\"handRaised\"])\r\n        );\r\n      }\r\n\r\n      match /occupancy/{seatId} {\r\n        allow read, write: if isProfessor();\r\n      }\r\n    }\r\n  }\r\n}\r\n"}]}}
